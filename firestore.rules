rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /documents/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Also allow guests to create if we want to support semi-anonymous checkouts
      allow create: if request.resource.data.userId == 'guest';
    }
    match /chat_logs/{logId} {
      allow create: if true; 
      allow read: if true; // Allow reading logs for pattern analysis (auto-learning)
    }
    match /dynamic_knowledge/{itemId} {
      allow read: if true; // Knowledge base must be public
      allow create: if true; // For auto-learning simulation
    }
  }
}
